# Meridian environment template.
# Copy to .env (gitignored). Per constitution §2.8, .env files MUST NEVER be committed.

# === Solana RPC ===
# Devnet defaults. Override with a paid RPC (Helius, QuickNode, Triton) for the
# automation service when free-tier rate limits start failing.
SOLANA_RPC_URL=https://api.devnet.solana.com
SOLANA_WS_URL=wss://api.devnet.solana.com
SOLANA_CLUSTER=devnet

# === Meridian program ===
# Filled by `anchor keys list` after the first `anchor build`. Slice 0 leaves it
# blank; slice 1 finalizes it.
MERIDIAN_PROGRAM_ID=ERtAbZetHFVmFKyTzfJd9LdMGsqu5b2TWeWc65sikPaX

# === Stable ===
# Circle's official devnet USDC mint. Do not change without amending plan.md D5.
USDC_MINT=4zMMC9srt5Ri5X14GAgXhaHii3GnPAEERYPJgZJDncDU

# === Pyth Network equity feed IDs (Hermes verified 2026-05-20) ===
# Source: https://hermes.pyth.network/v2/price_feeds?asset_type=equity
PYTH_FEED_AAPL=5a207c4aa0114baecf852fcd9db9beb8ec715f2db48caa525dbd878fd416fb09
PYTH_FEED_MSFT=8f98f8267ddddeeb61b4fd11f21dc0c2842c417622b4d685243fa73b5830131f
PYTH_FEED_GOOGL=88d0800b1649d98e21b8bf9c3f42ab548034d62874ad5d80e1c1b730566d7f61
PYTH_FEED_AMZN=82c59e36a8e0247e15283748d6cd51f5fa1019d73fbf3ab6d927e17d9e357a7f
PYTH_FEED_NVDA=61c4ca5b9731a79e285a01e24432d57d89f0ecdd4cd7828196ca8992d5eafef6
PYTH_FEED_META=399f1e8f1c4a517859963b56f104727a7a3c7f0f8fee56d34fa1f72e5a4b78ef
PYTH_FEED_TSLA=42676a595d0099c381687124805c8bb22c75424dffcaa55e3dc6549854ebe20a
PYTH_HERMES_URL=https://hermes.pyth.network

# === Keypair paths ===
# NEVER commit the actual keypair files. .gitignore blocks them; pre-commit also catches.
ADMIN_KEYPAIR_PATH=keypairs/admin.json
AUTOMATION_KEYPAIR_PATH=keypairs/automation.json
CRANKER_KEYPAIR_PATH=keypairs/cranker.json

# === Oracle validation thresholds (mirrored in on-chain Config) ===
PYTH_MAX_STALENESS_SECS=300
PYTH_MAX_CONFIDENCE_BPS=50
ADMIN_OVERRIDE_DELAY_SECS=3600

# === Automation service ===
PORT=8080
LOG_LEVEL=info
TZ=America/New_York
SLACK_WEBHOOK_URL=

# === Frontend (Next.js) ===
NEXT_PUBLIC_SOLANA_RPC_URL=https://api.devnet.solana.com
NEXT_PUBLIC_SOLANA_WS_URL=wss://api.devnet.solana.com
NEXT_PUBLIC_MERIDIAN_PROGRAM_ID=ERtAbZetHFVmFKyTzfJd9LdMGsqu5b2TWeWc65sikPaX
NEXT_PUBLIC_USDC_MINT=4zMMC9srt5Ri5X14GAgXhaHii3GnPAEERYPJgZJDncDU
NEXT_PUBLIC_CIRCLE_FAUCET_URL=https://faucet.circle.com
