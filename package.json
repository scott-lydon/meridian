{
  "name": "meridian",
  "private": true,
  "version": "0.1.0",
  "license": "MIT",
  "description": "Binary stock outcome markets on Solana devnet",
  "engines": {
    "node": ">=20",
    "pnpm": ">=11"
  },
  "packageManager": "pnpm@11.1.3",
  "scripts": {
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "format": "pnpm -r format && cargo fmt",
    "format:check": "pnpm -r format:check && cargo fmt --check",
    "anchor:build": "anchor build",
    "anchor:test": "anchor test",
    "anchor:clean": "anchor clean",
    "anchor:keys": "anchor keys list",
    "validator": "solana-test-validator --reset --quiet",
    "deploy:devnet": "anchor deploy --provider.cluster devnet",
    "seed:devnet": "cd tests && node ../scripts/seed-devnet.mjs",
    "seed:late": "cd tests && node ../scripts/seed-late-market.mjs",
    "dev": "concurrently --kill-others-on-fail --names validator,app,automation -c blue,green,magenta \"pnpm validator\" \"pnpm --filter @meridian/app dev\" \"pnpm --filter @meridian/automation dev\"",
    "preinstall": "npx only-allow pnpm"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "concurrently": "^9.0.0",
    "only-allow": "^1.2.1",
    "prettier": "^3.3.3",
    "typescript": "^5.5.0"
  }
}
